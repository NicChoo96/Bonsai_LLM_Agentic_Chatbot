# AI Backend
AI_BASE_URL=http://localhost:8080

# Working token limit — set BELOW the model's actual n_ctx to leave buffer.
# e.g. model has 16384 n_ctx → set this to ~12000 so compaction has room.
AI_CONTEXT_LIMIT=12000

# Continuous mode: max tokens for MEMORY.md before compaction triggers
CONTINUOUS_MEMORY_MAX_TOKENS=3000
